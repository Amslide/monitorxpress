{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "monitor-xpress",
  "version": "0.2.0",
  "identifier": "com.hafid.monitor-xpress",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Monitor Xpress",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": false,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "perMachine"
      }
    },
    "resources": {
      "resources/lhm/*": "lhm/",
      "resources/lhm/de/*": "lhm/de/",
      "resources/lhm/es/*": "lhm/es/",
      "resources/lhm/fr/*": "lhm/fr/",
      "resources/lhm/it/*": "lhm/it/",
      "resources/lhm/ja/*": "lhm/ja/",
      "resources/lhm/pl/*": "lhm/pl/",
      "resources/lhm/ru/*": "lhm/ru/",
      "resources/lhm/sv/*": "lhm/sv/",
      "resources/lhm/tr/*": "lhm/tr/",
      "resources/lhm/zh-CN/*": "lhm/zh-CN/",
      "resources/lhm/zh-Hant/*": "lhm/zh-Hant/"
    }
  }
}
